# Pinata IPFS Storage
PINATA_JWT=your_pinata_jwt_token
NEXT_PUBLIC_GATEWAY_URL=https://gateway.pinata.cloud

# Aleo Network (use "testnet" or "mainnet")
NEXT_PUBLIC_ALEO_NETWORK=testnet
NEXT_PUBLIC_ALEO_RPC_URL=https://api.explorer.provable.com/v2

# Deployed contract program IDs
NEXT_PUBLIC_PASSMEET_V1_PROGRAM_ID=passmeet_v1_7788.aleo
NEXT_PUBLIC_PASSMEET_SUBS_PROGRAM_ID=passmeet_subs_7788.aleo

# Token Registry (for USDCx/USAD when available)
# NEXT_PUBLIC_TOKEN_REGISTRY_PROGRAM_ID=token_registry.aleo
# NEXT_PUBLIC_USDCX_TOKEN_ID=123456789field
# NEXT_PUBLIC_USAD_TOKEN_ID=123456789field

# Auth: required for session/nonce routes (min 32 chars)
PASSMEET_AUTH_SECRET=your_random_32_char_secret_here
# Back-compat (optional)
# AUTH_SECRET=your_random_32_char_secret_here

# Production: canonical site URL for Open Graph / metadata
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
