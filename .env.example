# Pinata IPFS Storage
PINATA_JWT=your_pinata_jwt_token
NEXT_PUBLIC_GATEWAY_URL=https://gateway.pinata.cloud

# Aleo Network (use "testnet" or "mainnet")
NEXT_PUBLIC_ALEO_NETWORK=testnet
NEXT_PUBLIC_ALEO_RPC_URL=https://api.explorer.provable.com/v2
# JSON-RPC fallback for mapping reads (if Provable REST fails). testnet3.aleorpc.com is deprecated.
# NEXT_PUBLIC_ALEO_JSON_RPC=https://your-aleo-jsonrpc-endpoint

# Deployed contract program IDs
NEXT_PUBLIC_PASSMEET_V1_PROGRAM_ID=passmeet_v2_7788.aleo
NEXT_PUBLIC_PASSMEET_SUBS_PROGRAM_ID=passmeet_subs_v2_7788.aleo

# Token Registry (USDCx/USAD rails via token_registry.aleo)
# If these token IDs are not registered on-chain yet, run:
#   node scripts/register_and_mint_tokens.mjs <PRIVATE_KEY>
NEXT_PUBLIC_TOKEN_REGISTRY_PROGRAM_ID=token_registry.aleo
NEXT_PUBLIC_USDCX_TOKEN_ID=7788001field
NEXT_PUBLIC_USAD_TOKEN_ID=7788002field

# Auth: REQUIRED for session/nonce routes. Min 32 chars. Generate: openssl rand -base64 32
PASSMEET_AUTH_SECRET=your_random_32_char_secret_here
# Back-compat (optional)
# AUTH_SECRET=your_random_32_char_secret_here

# Production: canonical site URL for Open Graph / metadata
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
